# ============================================================================
# Tulistica — Environment Variables
# ============================================================================
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Generate strong secrets with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# ============================================================================

# ----------------------------------------------------------------------------
# Core
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# Public origin where the app is served (e.g. https://tulistica.com).
# Used for OAuth redirect URIs, social meta tags, and email links.
PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Database — MySQL via mysql2
# ----------------------------------------------------------------------------
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://root:password@localhost:3306/grocery_waze

# ----------------------------------------------------------------------------
# Authentication
# ----------------------------------------------------------------------------
# Secret used to sign session JWTs. MUST be at least 32 characters in prod.
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# OAuth provider — currently Manus webdev OAuth.
# To self-host, replace OAuth flow in server/_core/oauth.ts and sdk.ts.
VITE_APP_ID=your-oauth-client-id
OAUTH_SERVER_URL=https://oauth.example.com
# Optional: openId of the user that should be granted admin role on first sign-in.
OWNER_OPEN_ID=

# Client-side OAuth portal URL (used to construct the login URL).
VITE_OAUTH_PORTAL_URL=https://portal.example.com

# ----------------------------------------------------------------------------
# Forge API — proxies Google Maps, LLM, storage and notifications.
# If you self-host, replace the integrations in server/_core/{map,llm,storage,notification}.ts
# with direct Google Maps API + OpenAI/Anthropic + S3 + email/SMS calls.
# ----------------------------------------------------------------------------
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# ----------------------------------------------------------------------------
# Analytics (optional)
# ----------------------------------------------------------------------------
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ----------------------------------------------------------------------------
# Google Maps (optional, client-side)
# ----------------------------------------------------------------------------
# When set, the map view uses Google Maps tiles + markers. When empty, the
# map falls back to Leaflet + OpenStreetMap. Restrict this key by HTTP
# referrer in Google Cloud Console — it's exposed to the browser.
VITE_GOOGLE_MAPS_API_KEY=
