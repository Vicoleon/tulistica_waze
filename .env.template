# Database Configuration
# Format: mysql://user:password@host:port/database
# PRO TIP: If you have a local MySQL running, create a database named 'grocery_waze'
DATABASE_URL="mysql://root:password@localhost:3306/grocery_waze"

# Authentication / OAuth Configuration (Manus Platform)
# To bypass Manus auth for local dev, set this to true
MOCK_AUTH="true"

# The URL where the OAuth service is hosted. built for the 'Manus' platform.
# You will need the URL for the Manus OAuth service.
OAUTH_SERVER_URL="https://... (ask provider or check platform docs)"

# Your Application ID from the Manus platform.
VITE_APP_ID="app_..."

# Security
# A random string used to sign session cookies.
# You can generate one with: openssl rand -hex 32
JWT_SECRET="development_secret_key_change_me"

# Owner Configuration
# The OpenID of the user who owns/administers this instance.
# This might be your user ID on the Manus platform.
OWNER_OPEN_ID="user_..."

# External API Configuration (If applicable)
# These appear to be for an internal 'Forge' API.
BUILT_IN_FORGE_API_URL=""
BUILT_IN_FORGE_API_KEY=""
